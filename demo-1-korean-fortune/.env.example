# Copy this file to `.env` and fill in the values.
#   cp .env.example .env

# ── OpenAI ────────────────────────────────────────────────────────────────
# Optional. Without it, the demo falls back to a mock fortune generator.
OPENAI_API_KEY=

# ── Temporal connection ───────────────────────────────────────────────────
# Leave TEMPORAL_API_KEY empty to use a local `temporal server start-dev`
# instance. Set it to connect to Temporal Cloud instead.

# --- Option A: Local dev server (default) ---
TEMPORAL_ADDRESS=localhost:7233
TEMPORAL_NAMESPACE=default
TEMPORAL_API_KEY=

# --- Option B: Temporal Cloud ---
# Uncomment and fill in these values (and set your API key above) to use Cloud.
# TEMPORAL_ADDRESS=<your-namespace>.<account-id>.tmprl.cloud:7233
# TEMPORAL_NAMESPACE=<your-namespace>.<account-id>
# TEMPORAL_API_KEY=<your-temporal-cloud-api-key>
